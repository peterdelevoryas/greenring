# Public hostnames
APP_DOMAIN=localhost
LIVEKIT_DOMAIN=localhost

# Backend runtime
APP_BIND_ADDR=127.0.0.1:3000
APP_CORS_ORIGIN=http://127.0.0.1:5173
SESSION_COOKIE_NAME=greenring_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=720
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/greenring_local

# Local services
POSTGRES_DB=greenring_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_WS_URL=ws://127.0.0.1:7880
