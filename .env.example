# Public hostnames
APP_DOMAIN=localhost
LIVEKIT_DOMAIN=livekit.localhost

# Backend runtime
APP_BIND_ADDR=0.0.0.0:3000
APP_CORS_ORIGIN=http://localhost:5173
SESSION_COOKIE_NAME=greenring_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=720
DATABASE_URL=postgres://postgres:postgres@postgres:5432/greenring

# Local compose database
POSTGRES_DB=greenring
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=replace-this-secret
LIVEKIT_WS_URL=ws://localhost:7880
